# Required
ANTHROPIC_API_KEY=sk-ant-...

# Required for shareable report URLs
NEXT_PUBLIC_BASE_URL=https://spareklar.no

# Vercel KV — provisioned via Vercel dashboard (Storage > KV)
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# Resend — required for email report delivery (2.1)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=rapport@spareklar.no
# Optional: Resend audience ID for re-engagement list
# RESEND_AUDIENCE_ID=

# Optional (auto-injected by Vercel)
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID=
